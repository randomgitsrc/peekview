{
  "name": "peek-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.ts",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "vue": "^3.4",
    "vue-router": "^4.3",
    "shiki": "^1.6",
    "markdown-it": "^14.1",
    "markdown-it-anchor": "^9.0",
    "sanitize-html": "^2.13",
    "@iconify/vue": "^4.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0",
    "typescript": "^5.4",
    "vite": "^5.2",
    "vue-tsc": "^2.0",
    "vitest": "^1.5",
    "@vue/test-utils": "^2.4",
    "happy-dom": "^14.7",
    "@types/markdown-it": "^14.0",
    "@types/sanitize-html": "^2.11",
    "@playwright/test": "^1.43"
  }
