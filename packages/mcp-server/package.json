{
  "name": "@peekview/mcp-server",
  "version": "0.3.6",
  "description": "MCP Server for PeekView - AI Agent integration (SSE transport)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "peekview-mcp": "./dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "serve": "node dist/index.js serve",
    "test": "vitest run",
    "test:unit": "vitest run tests/server.test.ts tests/client.test.ts tests/config.test.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:e2e": "cd ../../frontend-v3 && npx playwright test e2e/mcp-server.spec.ts",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "prepublishOnly": "npm run build && npm run test:unit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "peekview",
    "ai",
    "agent",
    "claude",
    "sse"
  ],
  "author": "PeekView Team",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.4.0",
    "commander": "^14.0.3",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "pino": "^8.0.0",
    "uuid": "^11.0.0",
    "yaml": "^2.9.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^2.0.0",
    "msw": "^2.0.0",
    "pino-pretty": "^10.0.0",
    "supertest": "^6.3.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
